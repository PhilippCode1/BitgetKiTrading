{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/strategy-journal-summary-v1.json",
  "title": "StrategyJournalSummaryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "period_label_de",
    "themes_de",
    "playbook_performance_hints_de",
    "risk_events_de",
    "suggested_operator_followups_de",
    "summary_confidence_0_1"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "period_label_de": { "type": "string" },
    "themes_de": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string" }
    },
    "playbook_performance_hints_de": { "type": "string" },
    "risk_events_de": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string" }
    },
    "suggested_operator_followups_de": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string" }
    },
    "summary_confidence_0_1": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
