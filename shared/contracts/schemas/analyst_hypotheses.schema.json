{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/analyst-hypotheses-v1.json",
  "title": "AnalystHypothesesV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hypotheses",
    "chief_risk_de",
    "null_hypothesis_de",
    "confidence_0_1"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statement_de",
          "corroborates_direction",
          "confidence_0_1",
          "disconfirming_evidence_de"
        ],
        "properties": {
          "statement_de": { "type": "string" },
          "corroborates_direction": {
            "type": "string",
            "enum": ["long", "short", "neutral"]
          },
          "confidence_0_1": { "type": "number", "minimum": 0, "maximum": 1 },
          "disconfirming_evidence_de": { "type": "string" }
        }
      }
    },
    "chief_risk_de": { "type": "string" },
    "null_hypothesis_de": { "type": "string" },
    "confidence_0_1": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
