{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/safety-incident-diagnosis-v1.json",
  "title": "SafetyIncidentDiagnosisV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_authority",
    "incident_summary_de",
    "root_causes_de",
    "affected_services_de",
    "recommended_next_steps_de",
    "proposed_commands_de",
    "env_or_config_hints_de",
    "non_authoritative_note_de",
    "separation_note_de"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "execution_authority": {
      "type": "string",
      "const": "none",
      "description": "Nur Analyse und Vorschlaege; keine automatische Ausfuehrung, keine Aenderung geld-sensitiver Einstellungen."
    },
    "incident_summary_de": {
      "type": "string",
      "maxLength": 6000,
      "description": "Kurzfassung des Vorfalls aus Operatorensicht."
    },
    "root_causes_de": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "maxLength": 1200 }
    },
    "affected_services_de": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "maxLength": 240 }
    },
    "affected_repo_paths_de": {
      "type": "array",
      "maxItems": 24,
      "items": { "type": "string", "maxLength": 200 }
    },
    "recommended_next_steps_de": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "maxLength": 1200 }
    },
    "proposed_commands_de": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "maxLength": 500 },
      "description": "Nur als lesbare Vorschlaege formuliert; niemals still ausfuehren."
    },
    "env_or_config_hints_de": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "maxLength": 200 },
      "description": "Namen von ENV-Variablen oder Config-Schluesseln — keine Geheimniswerte."
    },
    "non_authoritative_note_de": {
      "type": "string",
      "maxLength": 2000
    },
    "separation_note_de": {
      "type": "string",
      "maxLength": 1200,
      "description": "Klarstellung: keine Live-Aktion, keine Order-/Limit-Aenderung durch diese KI."
    }
  }
}
