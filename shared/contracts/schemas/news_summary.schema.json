{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/news-summary-v1.json",
  "title": "NewsSummaryStructured",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "headline_de",
    "summary_de",
    "relevance_score_0_100",
    "sentiment_neg1_to_1",
    "impact_keywords",
    "entities_mentioned",
    "confidence_0_1"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "headline_de": {
      "type": "string",
      "description": "Kurze Schlagzeile auf Deutsch"
    },
    "summary_de": {
      "type": "string",
      "description": "2-4 Saetze Zusammenfassung Deutsch"
    },
    "relevance_score_0_100": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "sentiment_neg1_to_1": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "impact_keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entities_mentioned": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence_0_1": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "impact_window": {
      "type": "string",
      "description": "Erwarteter Preis-Reaktionshorizont",
      "enum": ["sofort", "mittel", "langsam"]
    }
  }
}
