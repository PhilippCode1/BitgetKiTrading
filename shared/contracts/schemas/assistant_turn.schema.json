{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/assistant-turn-v1.json",
  "title": "AssistantTurnV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_authority",
    "assist_role_echo",
    "assistant_reply_de",
    "referenced_context_keys_de",
    "retrieval_citations_de",
    "trade_separation_note_de",
    "non_authoritative_note_de"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "execution_authority": {
      "type": "string",
      "const": "none",
      "description": "Assistenz ohne Order- oder Limit-Hoheit."
    },
    "assist_role_echo": {
      "type": "string",
      "description": "Server setzt const=angefragte Rolle vor Validierung."
    },
    "assistant_reply_de": { "type": "string" },
    "referenced_context_keys_de": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string" }
    },
    "retrieval_citations_de": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string" }
    },
    "trade_separation_note_de": {
      "type": "string",
      "description": "Kurz: keine Trade-Ausfuehrung durch diese KI."
    },
    "non_authoritative_note_de": { "type": "string" }
  }
}
