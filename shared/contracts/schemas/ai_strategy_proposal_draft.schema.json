{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitget-btc-ai.local/schemas/ai-strategy-proposal-draft-v1.json",
  "title": "AiStrategyProposalDraftV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_authority",
    "strategy_explanation_de",
    "scenario_variants_de",
    "parameter_ideas_de",
    "validity_and_assumptions_de",
    "risk_and_caveats_de",
    "referenced_input_keys_de",
    "non_authoritative_note_de",
    "promotion_disclaimer_de",
    "suggested_execution_lane_hint"
  ],
  "$defs": {
    "line_style": {
      "type": "string",
      "enum": ["solid", "dashed", "dotted"]
    },
    "marker_shape": {
      "type": "string",
      "enum": ["circle", "square", "arrow_up", "arrow_down"]
    },
    "chart_annotations_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "horizontal_lines": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["price"],
            "properties": {
              "price": { "type": "number" },
              "label": { "type": "string", "maxLength": 80 },
              "line_style": { "$ref": "#/$defs/line_style" }
            }
          }
        },
        "price_bands": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["price_high", "price_low"],
            "properties": {
              "price_high": { "type": "number" },
              "price_low": { "type": "number" },
              "label": { "type": "string", "maxLength": 80 },
              "line_style": { "$ref": "#/$defs/line_style" }
            }
          }
        },
        "time_markers": {
          "type": "array",
          "maxItems": 24,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["time_unix_s"],
            "properties": {
              "time_unix_s": { "type": "integer" },
              "label": { "type": "string", "maxLength": 64 },
              "shape": { "$ref": "#/$defs/marker_shape" }
            }
          }
        },
        "line_segments": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "time_a_unix_s",
              "price_a",
              "time_b_unix_s",
              "price_b"
            ],
            "properties": {
              "time_a_unix_s": { "type": "integer" },
              "price_a": { "type": "number" },
              "time_b_unix_s": { "type": "integer" },
              "price_b": { "type": "number" },
              "label": { "type": "string", "maxLength": 64 },
              "line_style": { "$ref": "#/$defs/line_style" }
            }
          }
        },
        "vertical_rules": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["time_unix_s", "price_low", "price_high"],
            "properties": {
              "time_unix_s": { "type": "integer" },
              "price_low": { "type": "number" },
              "price_high": { "type": "number" },
              "label": { "type": "string", "maxLength": 64 },
              "line_style": { "$ref": "#/$defs/line_style" }
            }
          }
        },
        "uncertainty_regions": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "time_from_unix_s",
              "time_to_unix_s",
              "price_high",
              "price_low"
            ],
            "properties": {
              "time_from_unix_s": { "type": "integer" },
              "time_to_unix_s": { "type": "integer" },
              "price_high": { "type": "number" },
              "price_low": { "type": "number" },
              "label": { "type": "string", "maxLength": 80 }
            }
          }
        },
        "chart_notes_de": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "text": { "type": "string", "maxLength": 220 }
            }
          }
        }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "execution_authority": {
      "type": "string",
      "const": "none",
      "description": "Konstante: keine Order- oder Broker-Hoheit durch dieses Objekt."
    },
    "strategy_explanation_de": {
      "type": "string",
      "description": "Kernaussage: Lesung von Chart+Signal-Kontext als Entwurf, nicht als verbindliche Handlung."
    },
    "scenario_variants_de": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "maxLength": 500 },
      "description": "Benannte Szenarien (z. B. bull/base/bear) als Text — keine ausführbaren Regeln."
    },
    "parameter_ideas_de": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "maxLength": 240 },
      "description": "Heuristische Parameter-Ideen (Stops, Größen, Zeitfenster) — nur zur menschlichen Bewertung."
    },
    "validity_and_assumptions_de": {
      "type": "string",
      "maxLength": 2000,
      "description": "Gültigkeit, Annahmen, wann der Entwurf obsolet wird."
    },
    "risk_and_caveats_de": {
      "type": "string",
      "description": "Risiken, Datenlücken, Modellgrenzen."
    },
    "referenced_input_keys_de": {
      "type": "array",
      "maxItems": 32,
      "items": { "type": "string" },
      "description": "Welche Keys aus dem Kontext-JSON die Antwort maßgeblich beeinflusst haben."
    },
    "non_authoritative_note_de": {
      "type": "string",
      "description": "Standard-Hinweis: KI kann irren; kein Ersatz für Risk-Gates."
    },
    "promotion_disclaimer_de": {
      "type": "string",
      "maxLength": 600,
      "description": "Explizit: Vorschlag ist kein Order; Umsetzung nur nach Prüfung und Produktfreigaben."
    },
    "suggested_execution_lane_hint": {
      "type": "string",
      "enum": [
        "none",
        "paper_sandbox",
        "shadow_observe",
        "live_requires_full_gates"
      ],
      "description": "Nicht-bindende Stufe für menschliche Priorisierung — löst keine Ausführung aus."
    },
    "chart_annotations": {
      "description": "Optionale KI-Chart-Overlays (gleiches Format wie strategy_signal_explain).",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/chart_annotations_v1" }]
    }
  }
}
