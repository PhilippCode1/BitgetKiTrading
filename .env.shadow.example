# === Profil: shadow ===
# Copy to `.env.shadow`. PRODUCTION=true | APP_ENV=shadow | EXECUTION_MODE=shadow
# Pflicht-ENV fuer validate_env_profile: unten shadow_ex_only_* / sk-example-* nur Vorlagen —
# vor Deploy durch Secrets aus Vault/Store ersetzen (docs/SECRETS_MATRIX.md, docs/operator_urls_and_secrets.md).
# Keine Demo-/Fixture-/Fake-Provider-/Dry-Run-Defaults — siehe docs/env_profiles.md
# und Validierung in config/settings.py (`_prod_safety`).
#
# Single-Host Docker Compose (empfohlen):
#   export COMPOSE_ENV_FILE=.env.shadow
#   docker compose -f docker-compose.yml up -d --build
# LIVE_BROKER_* unten mit Docker-Dienstnamen (nicht externe Hostnamen), sonst schlagen
# Consumer im Netz bitget_ai_net fehl.
# Nutze DATABASE_URL_DOCKER / REDIS_URL_DOCKER mit Dienstnamen postgres, redis (wie unten).
# DATABASE_URL / REDIS_URL = Erreichbarkeit vom Host oder externem Netz (nicht localhost in Prod-Pfaden).
# Oeffentliche URLs (APP_BASE_URL, FRONTEND_URL, NEXT_PUBLIC_*, CORS): docs/operator_urls_and_secrets.md
# Website<->API: dieselben Hosts fuer Gateway + Browser (NEXT_PUBLIC_* = was der Client laedt; CORS = FRONTEND_URL).
#
# Platzhalter example.com / example.internal in oeffentlichen URLs: vor Deploy ersetzen
# (oder komplett durch docker-interne Hosts nur fuer DB/Redis, siehe unten).

# ---------- Core / Runtime ----------
PRODUCTION=true
# BITGET_ALLOW_DEMO_SCHEMA_SEEDS niemals true (nur lokaler Demo-SQL-Pfad; validate_env_profile schlaegt sonst fehl).
APP_ENV=shadow
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
VAULT_MODE=hashicorp
VAULT_ADDR=https://vault.shadow.example.internal
VAULT_TOKEN=<SET_ME>
VAULT_ROLE_ID=<SET_ME>
VAULT_SECRET_ID=<SET_ME>
KMS_KEY_ID=<SET_ME>
DEPLOY_ENV=shadow
DEPLOY_SCRIPT=scripts/deploy.sh
ENABLE_DEBUG_METRICS=false
GIT_REPO=https://example.com/org/bitget-btc-ai

# ---------- Trading / Live / Risk ----------
EXECUTION_MODE=shadow
STRATEGY_EXEC_MODE=manual
SHADOW_TRADE_ENABLE=true
LIVE_TRADE_ENABLE=false
LIVE_BROKER_PORT=8120
LIVE_BROKER_ENABLED=true
LIVE_BROKER_BASE_URL=http://live-broker:8120
LIVE_BROKER_WS_PRIVATE_URL=ws://live-broker:8120/ws/private
LIVE_BROKER_CONSUMER_GROUP=live-broker
LIVE_BROKER_CONSUMER_NAME=lb-1
LIVE_BROKER_SIGNAL_STREAM=events:signal_created
LIVE_BROKER_REFERENCE_STREAMS=events:trade_opened,events:trade_updated,events:trade_closed
ORDER_IDEMPOTENCY_PREFIX=bgai-shadow
LIVE_RECONCILE_INTERVAL_SEC=15
LIVE_KILL_SWITCH_ENABLED=true
INSTRUMENT_CATALOG_REFRESH_INTERVAL_SEC=300
INSTRUMENT_CATALOG_CACHE_TTL_SEC=900
INSTRUMENT_CATALOG_MAX_STALE_SEC=1800
# explizite Startkohorte — nur echte Symbole aus Discovery/Operator-Allowlist
LIVE_ALLOWED_SYMBOLS=<SET_OPERATOR_LIVE_ALLOWLIST_SYMBOLS>
LIVE_ALLOWED_MARKET_FAMILIES=futures,spot,margin
LIVE_ALLOWED_PRODUCT_TYPES=USDT-FUTURES
LIVE_REQUIRE_ASSET_ELIGIBILITY=true
LIVE_REQUIRE_EXCHANGE_HEALTH=true
LIVE_REQUIRE_EXECUTION_BINDING=true
LIVE_REQUIRE_OPERATOR_RELEASE_FOR_LIVE_OPEN=true
LIVE_BROKER_HTTP_TIMEOUT_SEC=10
LIVE_BROKER_HTTP_MAX_RETRIES=2
LIVE_BROKER_HTTP_RETRY_BASE_SEC=0.25
LIVE_BROKER_HTTP_RETRY_MAX_SEC=2.0
LIVE_BROKER_CIRCUIT_FAIL_THRESHOLD=3
LIVE_BROKER_CIRCUIT_OPEN_SEC=30
LIVE_BROKER_SERVER_TIME_SYNC_SEC=20
LIVE_BROKER_SERVER_TIME_MAX_SKEW_MS=5000
LIVE_ORDER_TIMEOUT_SEC=300
LIVE_EXITS_ENABLED=true
REQUIRE_SHADOW_MATCH_BEFORE_LIVE=true
RISK_HARD_GATING_ENABLED=true
RISK_ALLOWED_LEVERAGE_MIN=7
RISK_ALLOWED_LEVERAGE_MAX=7
RISK_REQUIRE_7X_APPROVAL=true
RISK_DEFAULT_ACTION=do_not_trade
RISK_MIN_SIGNAL_STRENGTH=65
RISK_MIN_PROBABILITY=0.65
RISK_MIN_RISK_SCORE=60
RISK_MIN_EXPECTED_RETURN_BPS=5
RISK_MAX_EXPECTED_MAE_BPS=120
RISK_MIN_PROJECTED_RR=1.15
RISK_MAX_POSITION_RISK_PCT=0.02
RISK_MAX_ACCOUNT_MARGIN_USAGE=0.35
RISK_MAX_ACCOUNT_DRAWDOWN_PCT=0.10
RISK_MAX_DAILY_DRAWDOWN_PCT=0.04
RISK_MAX_WEEKLY_DRAWDOWN_PCT=0.08
RISK_MAX_DAILY_LOSS_USDT=750
RISK_MAX_POSITION_NOTIONAL_USDT=5000
RISK_MAX_CONCURRENT_POSITIONS=1
RISK_FORCE_REDUCE_ONLY_ON_ALERT=true
RISK_GOVERNOR_LIVE_RAMP_MAX_LEVERAGE=7

# ---------- Model Ops / Security ----------
MODEL_OPS_ENABLED=true
MODEL_OPS_REGISTRY_URI=https://mlflow.shadow.example.internal
MODEL_OPS_ACTIVE_MODEL_TAG=signal-v1-shadow
MODEL_OPS_APPROVAL_REQUIRED=true
MODEL_OPS_SHADOW_EVAL_ENABLED=true
MODEL_OPS_DRIFT_ALERT_THRESHOLD=0.15
MODEL_OPS_ROLLBACK_ON_DRIFT=true
MODEL_OPS_MIN_SAMPLE_SIZE=50
API_AUTH_MODE=api_key
SECURITY_REQUIRE_INTERNAL_NETWORK=true
SECURITY_ALLOW_EVENT_DEBUG_ROUTES=false
SECURITY_ALLOW_DB_DEBUG_ROUTES=false
SECURITY_ALLOW_ALERT_REPLAY_ROUTES=false
INTERNAL_API_KEY=<CHANGEME>
ADMIN_TOKEN=<CHANGEME>
SECRET_KEY=<CHANGEME>
JWT_SECRET=<CHANGEME>
ENCRYPTION_KEY=<CHANGEME>

# ---------- Gateway (Pflicht: Secret aus Store; kein Legacy-Admin in Prod-Pfaden) ----------
GATEWAY_ENFORCE_SENSITIVE_AUTH=true
GATEWAY_JWT_SECRET=<CHANGEME>
GATEWAY_JWT_AUDIENCE=api-gateway
GATEWAY_JWT_ISSUER=bitget-btc-ai-gateway
# Audit-ledger signing seed; shadow value must be distinct from production.
APEX_AUDIT_LEDGER_ED25519_SEED_HEX=<CHANGEME>
# Optional: X-Gateway-Internal-Key — nicht INTERNAL_API_KEY; leer = Header deaktiviert
GATEWAY_INTERNAL_API_KEY=
GATEWAY_ALLOW_LEGACY_ADMIN_TOKEN=false
GATEWAY_SEND_HSTS=true
GATEWAY_SSE_COOKIE_SECURE=true
GATEWAY_SSE_COOKIE_SAMESITE=lax
GATEWAY_RL_PUBLIC_PER_MINUTE=120
GATEWAY_RL_SENSITIVE_PER_MINUTE=60
GATEWAY_RL_ADMIN_MUTATE_PER_MINUTE=20
DASHBOARD_GATEWAY_AUTHORIZATION=Bearer <CHANGEME>

