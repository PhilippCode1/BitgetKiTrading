# ---------- Data Stores ----------
# POSTGRES_PASSWORD = einzige Passwort-Wahrheit; URLs muessen dasselbe Passwort enthalten.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bitget_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGEME>
# Externer/verwalteter Endpunkt oder Host-Port-Forward — nicht „postgres“ ohne Docker-Netz
DATABASE_URL=postgresql://postgres:<CHANGEME>@db.shadow.example.internal:5432/bitget_ai
DATABASE_URL_DOCKER=postgresql://postgres:<CHANGEME>@postgres:5432/bitget_ai
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis.shadow.example.internal:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
EVENTBUS_DEFAULT_BLOCK_MS=2000
EVENTBUS_DEFAULT_COUNT=50
EVENTBUS_DEDUPE_TTL_SEC=86400

# ---------- Service Ports ----------
