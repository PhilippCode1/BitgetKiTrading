{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@bitget-btc-ai/shared-ts": ["../../shared/ts/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    ".next/types/**/*.ts",
    "build/types/**/*.ts",
    "build-cursor/types/**/*.ts",
    "build-cursor/dev/types/**/*.ts",
    "build/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next/dev", "build/dev"]
}
