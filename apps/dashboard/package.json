{
  "name": "@bitget-btc-ai/dashboard",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node build/standalone/apps/dashboard/server.js",
    "check-types": "tsc --noEmit",
    "check-locale-de": "node ../../scripts/check_dashboard_de_copy.mjs",
    "lint": "pnpm run check-types",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
