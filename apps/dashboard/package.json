    "test:ci": "jest --coverage --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@bitget-btc-ai/shared-ts": "workspace:*",
    "jose": "^5.10.0",
    "lightweight-charts": "4.2.3",
