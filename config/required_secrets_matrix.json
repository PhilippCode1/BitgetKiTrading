{
  "version": 2,
  "description": "Key → Services → Pflicht je Phase: local (Dev/Paper), staging (APP_ENV=shadow, Pre-Prod; CLI-Profil staging|shadow), production (APP_ENV=production). Spalten staging/production sind heute inhaltlich gleich — bewusst getrennt fuer spaetere Abweichungen. Auth-/Secret-Semantik: docs/SECRETS_MATRIX.md, docs/operator_urls_and_secrets.md, CONFIGURATION.md.",
  "services_all": [
    "api-gateway",
    "alert-engine",
    "audit-ledger",
    "drawing-engine",
    "feature-engine",
    "learning-engine",
    "live-broker",
    "llm-orchestrator",
    "inference-server",
    "market-stream",
    "monitor-engine",
    "news-engine",
    "paper-broker",
    "signal-engine",
    "structure-engine"
  ],
  "entries": [
    {
      "env": "POSTGRES_PASSWORD",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "DATABASE_URL",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "DATABASE_URL_DOCKER",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "REDIS_URL",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "REDIS_URL_DOCKER",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "JWT_SECRET",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "SECRET_KEY",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "ADMIN_TOKEN",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "ENCRYPTION_KEY",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "INTERNAL_API_KEY",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "GATEWAY_JWT_SECRET",
      "services": ["api-gateway"],
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "API_GATEWAY_URL",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "NEXT_PUBLIC_API_BASE_URL",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "NEXT_PUBLIC_WS_BASE_URL",
      "services": "*",
      "local": "required",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "DASHBOARD_GATEWAY_AUTHORIZATION",
      "services": "*",
      "local": "optional",
      "staging": "required",
      "production": "required"
    },
    {
      "env": "APEX_AUDIT_LEDGER_ED25519_SEED_HEX",
      "services": ["audit-ledger"],
      "local": "optional",
      "staging": "required",
      "production": "required"
    }
  ]
}
