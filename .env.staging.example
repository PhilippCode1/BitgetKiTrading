# === Profil: staging ===
# Staging is implemented as APP_ENV=shadow + DEPLOY_ENV=staging.
# Rationale: reuse production-hardening and shadow/live gates without adding a
# new APP_ENV runtime branch. Staging must never use production DB/Redis or real
# customer data, and must never submit real orders.

PRODUCTION=true
APP_ENV=shadow
DEPLOY_ENV=staging
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
VAULT_MODE=hashicorp
VAULT_ADDR=https://vault.staging.example.internal
VAULT_TOKEN=<SET_ME>
VAULT_ROLE_ID=<SET_ME>
VAULT_SECRET_ID=<SET_ME>
KMS_KEY_ID=<SET_ME>

# ---------- Runtime / URLs ----------
APP_BASE_URL=https://api.staging.example.com
FRONTEND_URL=https://dashboard.staging.example.com
API_GATEWAY_URL=https://api.staging.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.staging.example.com
NEXT_PUBLIC_WS_BASE_URL=wss://api.staging.example.com
CORS_ALLOW_ORIGINS=https://dashboard.staging.example.com
GIT_REPO=https://example.com/org/bitget-btc-ai

# ---------- Data stores: staging only, never production ----------
POSTGRES_PASSWORD=<SET_ME>
DATABASE_URL=postgresql://bitget_app:<SET_ME>@postgres.staging.example.internal:5432/bitget_btc_ai_staging
DATABASE_URL_DOCKER=postgresql://bitget_app:<SET_ME>@postgres:5432/bitget_btc_ai_staging
REDIS_PASSWORD=<SET_ME>
REDIS_URL=redis://:<SET_ME>@redis.staging.example.internal:6379/0
REDIS_URL_DOCKER=redis://:<SET_ME>@redis:6379/0

# ---------- Trading / live-broker safety ----------
EXECUTION_MODE=shadow
STRATEGY_EXEC_MODE=manual
SHADOW_TRADE_ENABLE=true
LIVE_TRADE_ENABLE=false
LIVE_BROKER_ENABLED=true
LIVE_BROKER_PORT=8120
LIVE_BROKER_BASE_URL=https://live-broker.staging.example.internal
LIVE_BROKER_WS_PRIVATE_URL=wss://live-broker.staging.example.internal/ws/private
LIVE_RECONCILE_INTERVAL_SEC=15
LIVE_KILL_SWITCH_ENABLED=true
LIVE_REQUIRE_EXCHANGE_HEALTH=true
LIVE_REQUIRE_OPERATOR_RELEASE_FOR_LIVE_OPEN=true
REQUIRE_SHADOW_MATCH_BEFORE_LIVE=true
RISK_HARD_GATING_ENABLED=true
RISK_REQUIRE_7X_APPROVAL=true
RISK_DEFAULT_ACTION=do_not_trade
RISK_ALLOWED_LEVERAGE_MIN=7
RISK_ALLOWED_LEVERAGE_MAX=7
LIVE_ALLOWED_MARKET_FAMILIES=futures
LIVE_ALLOWED_PRODUCT_TYPES=USDT-FUTURES
LIVE_ALLOWED_SYMBOLS=<SET_OPERATOR_STAGING_ALLOWLIST_SYMBOLS>
ORDER_IDEMPOTENCY_PREFIX=bgai-staging

# ---------- Auth / service secrets ----------
API_AUTH_MODE=api_key
GATEWAY_ENFORCE_SENSITIVE_AUTH=true
GATEWAY_ALLOW_LEGACY_ADMIN_TOKEN=false
SECURITY_REQUIRE_INTERNAL_NETWORK=true
SECURITY_ALLOW_EVENT_DEBUG_ROUTES=false
SECURITY_ALLOW_DB_DEBUG_ROUTES=false
SECURITY_ALLOW_ALERT_REPLAY_ROUTES=false
INTERNAL_API_KEY=<SET_ME>
SERVICE_INTERNAL_API_KEY=<SET_ME>
GATEWAY_INTERNAL_API_KEY=<SET_ME>
SECRET_KEY=<SET_ME>
JWT_SECRET=<SET_ME>
GATEWAY_JWT_SECRET=<SET_ME>
GATEWAY_JWT_AUDIENCE=api-gateway
GATEWAY_JWT_ISSUER=bitget-btc-ai-gateway
DASHBOARD_GATEWAY_AUTHORIZATION=Bearer <SET_ME>
ADMIN_TOKEN=<SET_ME>
ENCRYPTION_KEY=<SET_ME>
APEX_AUDIT_LEDGER_ED25519_SEED_HEX=<SET_ME>

# ---------- Commercial / tenant gates prepared, no live submit ----------
COMMERCIAL_ENABLED=true
COMMERCIAL_ENTITLEMENT_ENFORCE=true
COMMERCIAL_REQUIRE_CONTRACT_FOR_LIVE=true
COMMERCIAL_TELEGRAM_REQUIRED_FOR_CONSOLE=true
COMMERCIAL_DEFAULT_TENANT_ID=staging-tenant
COMMERCIAL_METER_SECRET=<SET_ME>

# ---------- Providers: real pre-prod providers optional, fake/fixtures off ----------
LLM_USE_FAKE_PROVIDER=false
OPENAI_API_KEY=<SET_ME>
NEWS_FIXTURE_MODE=false
PAPER_SIM_MODE=false
TELEGRAM_DRY_RUN=false
TELEGRAM_BOT_TOKEN=<SET_ME>
TELEGRAM_WEBHOOK_SECRET=<SET_ME>
TELEGRAM_BOT_USERNAME=<SET_ME>

# ---------- Bitget: read-only verification allowed, writes forbidden ----------
BITGET_DEMO_ENABLED=false
BITGET_RELAX_CREDENTIAL_ISOLATION=false
BITGET_READ_ONLY_CHECK_ENABLED=false
BITGET_WRITE_ENABLED=false
BITGET_API_KEY=<SET_ME>
BITGET_API_SECRET=<SET_ME>
BITGET_API_PASSPHRASE=<SET_ME>
BITGET_MARKET_FAMILY=futures
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_FUTURES_DEFAULT_PRODUCT_TYPE=USDT-FUTURES
BITGET_SYMBOL=BTCUSDT
BITGET_DISCOVERY_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_UNIVERSE_SYMBOLS=<SET_REAL_VISIBLE_UNIVERSE_SYMBOLS_FROM_DISCOVERY>
BITGET_UNIVERSE_MARKET_FAMILIES=spot,margin,futures

# ---------- Readiness URLs ----------
HEALTH_URL_API_GATEWAY=https://api.staging.example.com/ready
HEALTH_URL_DASHBOARD=https://dashboard.staging.example.com
HEALTH_URL_MARKET_STREAM=https://market-stream.staging.example.internal/ready
HEALTH_URL_FEATURE_ENGINE=https://feature-engine.staging.example.internal/ready
HEALTH_URL_STRUCTURE_ENGINE=https://structure-engine.staging.example.internal/ready
HEALTH_URL_SIGNAL_ENGINE=https://signal-engine.staging.example.internal/ready
HEALTH_URL_DRAWING_ENGINE=https://drawing-engine.staging.example.internal/ready
HEALTH_URL_NEWS_ENGINE=https://news-engine.staging.example.internal/ready
HEALTH_URL_LLM_ORCHESTRATOR=https://llm-orchestrator.staging.example.internal/ready
HEALTH_URL_PAPER_BROKER=https://paper-broker.staging.example.internal/ready
HEALTH_URL_LEARNING_ENGINE=https://learning-engine.staging.example.internal/ready
HEALTH_URL_ALERT_ENGINE=https://alert-engine.staging.example.internal/ready
HEALTH_URL_MONITOR_ENGINE=https://monitor-engine.staging.example.internal/ready
HEALTH_URL_LIVE_BROKER=https://live-broker.staging.example.internal/ready
LLM_ORCH_BASE_URL=https://llm-orchestrator.staging.example.internal

# ---------- Dashboard public flags: no secrets ----------
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=bitget-btc-ai
NEXT_PUBLIC_ENABLE_ADMIN=false
NEXT_PUBLIC_ENABLE_TELEGRAM_STATUS=true
