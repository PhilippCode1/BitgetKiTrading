# NUR fuer CI/Smoke: bewusst `API_GATEWAY_URL` mit 127.0.0.1, damit validate_env_profile (production) scheitert.
# Keine echten Secrets — konstante Dummy-Werte, ausreichend Laenge fuer Matrix-Validation.
# Erwartung: Exit 1, Meldung zu API_GATEWAY_URL / Loopback.
PRODUCTION=true
APP_ENV=production
LLM_USE_FAKE_PROVIDER=false
LLM_ORCH_BASE_URL=http://llm-orchestrator:8070
OPENAI_API_KEY=sk-dummy-openai-key-for-validate-smoke-32b
POSTGRES_PASSWORD=dummy_postgres_password_32_chars____
DATABASE_URL=postgresql://u:dummy@db.example.com:5432/app
DATABASE_URL_DOCKER=postgresql://u:dummy@postgres:5432/app
REDIS_URL=redis://redis.prod.example:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
JWT_SECRET=dummy_jwt_secret_minimum_32_characters_
SECRET_KEY=unit_secret_key_minimum_32_characters
ADMIN_TOKEN=unit_admin_token_for_tests_only________
ENCRYPTION_KEY=unit_encryption_key_32_chars_min______
INTERNAL_API_KEY=unit_internal_api_key_min_32_chars_x
GATEWAY_JWT_SECRET=unit-test-gateway-jwt-secret-32b!
API_GATEWAY_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_WS_BASE_URL=wss://api.example.com
DASHBOARD_GATEWAY_AUTHORIZATION=Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0In0.smoke
APEX_AUDIT_LEDGER_ED25519_SEED_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
