# === Profil: test (Pytest / CI) ===
# Copy to `.env.test`. PRODUCTION=false | APP_ENV=test
# Fixture/Fake/Demo sind hier erlaubt (Determinismus). Nicht als Shadow/Production-Profil verwenden.
# Katalog: `.env.example` | Vertrag: docs/env_profiles.md
# Website<->API in Tests: typisch localhost; CORS/ NEXT_PUBLIC_* wie in CI/.github/workflows gesetzt.

PRODUCTION=false
APP_ENV=test
DEPLOY_ENV=test
DEBUG=false
LOG_LEVEL=WARNING
LOG_FORMAT=plain
VAULT_MODE=false
CI=true
NODE_ENV=test

EXECUTION_MODE=paper
STRATEGY_EXEC_MODE=manual
SHADOW_TRADE_ENABLE=false
LIVE_TRADE_ENABLE=false
LIVE_BROKER_PORT=8120
LIVE_BROKER_ENABLED=false
LIVE_BROKER_BASE_URL=http://localhost:9080
LIVE_BROKER_WS_PRIVATE_URL=ws://localhost:9080/ws/private
LIVE_BROKER_CONSUMER_GROUP=live-broker
LIVE_BROKER_CONSUMER_NAME=lb-test
LIVE_BROKER_SIGNAL_STREAM=events:signal_created
LIVE_BROKER_REFERENCE_STREAMS=events:trade_opened,events:trade_updated,events:trade_closed
ORDER_IDEMPOTENCY_PREFIX=bgai-test
LIVE_RECONCILE_INTERVAL_SEC=15
LIVE_KILL_SWITCH_ENABLED=true
INSTRUMENT_CATALOG_REFRESH_INTERVAL_SEC=60
INSTRUMENT_CATALOG_CACHE_TTL_SEC=120
INSTRUMENT_CATALOG_MAX_STALE_SEC=300
LIVE_ALLOWED_SYMBOLS=
LIVE_ALLOWED_MARKET_FAMILIES=
LIVE_ALLOWED_PRODUCT_TYPES=
LIVE_REQUIRE_EXCHANGE_HEALTH=false
LIVE_REQUIRE_EXECUTION_BINDING=false
LIVE_REQUIRE_OPERATOR_RELEASE_FOR_LIVE_OPEN=false
LIVE_BROKER_HTTP_TIMEOUT_SEC=10
LIVE_BROKER_HTTP_MAX_RETRIES=1
LIVE_BROKER_HTTP_RETRY_BASE_SEC=0.01
LIVE_BROKER_HTTP_RETRY_MAX_SEC=0.05
LIVE_BROKER_CIRCUIT_FAIL_THRESHOLD=2
LIVE_BROKER_CIRCUIT_OPEN_SEC=1
LIVE_BROKER_SERVER_TIME_SYNC_SEC=5
LIVE_BROKER_SERVER_TIME_MAX_SKEW_MS=5000
LIVE_ORDER_TIMEOUT_SEC=60
LIVE_EXITS_ENABLED=true
REQUIRE_SHADOW_MATCH_BEFORE_LIVE=false
RISK_HARD_GATING_ENABLED=true
RISK_ALLOWED_LEVERAGE_MIN=7
RISK_ALLOWED_LEVERAGE_MAX=75
RISK_REQUIRE_7X_APPROVAL=true
RISK_DEFAULT_ACTION=do_not_trade
RISK_MIN_SIGNAL_STRENGTH=65
RISK_MIN_PROBABILITY=0.65
RISK_MIN_RISK_SCORE=60
RISK_MIN_EXPECTED_RETURN_BPS=5
RISK_MAX_EXPECTED_MAE_BPS=120
RISK_MIN_PROJECTED_RR=1.15
RISK_MAX_POSITION_RISK_PCT=0.02
RISK_MAX_ACCOUNT_MARGIN_USAGE=0.35
RISK_MAX_ACCOUNT_DRAWDOWN_PCT=0.10
RISK_MAX_DAILY_DRAWDOWN_PCT=0.04
RISK_MAX_WEEKLY_DRAWDOWN_PCT=0.08
RISK_MAX_DAILY_LOSS_USDT=1000
RISK_MAX_POSITION_NOTIONAL_USDT=5000
RISK_MAX_CONCURRENT_POSITIONS=1
RISK_GOVERNOR_LIVE_RAMP_MAX_LEVERAGE=7
FEATURE_MAX_EVENT_AGE_MS=120000
SIGNAL_MAX_DATA_AGE_MS=300000
SIGNAL_MAX_STRUCTURE_AGE_MS=300000
SIGNAL_MAX_DRAWING_AGE_MS=300000
SIGNAL_MAX_NEWS_AGE_MS=3600000
SIGNAL_MAX_ORDERBOOK_AGE_MS=20000
SIGNAL_MAX_FUNDING_FEATURE_AGE_MS=900000
SIGNAL_MAX_OPEN_INTEREST_AGE_MS=300000
SIGNAL_MAX_SPREAD_BPS=8
SIGNAL_MAX_EXECUTION_COST_BPS=18
SIGNAL_MAX_ADVERSE_FUNDING_BPS=5
TAKE_TRADE_MODEL_REFRESH_MS=1000
MODEL_MAX_UNCERTAINTY=0.55
MODEL_OOD_ROBUST_Z_THRESHOLD=6.0
MODEL_OOD_MAX_FLAGGED_FEATURES=2
MODEL_SHADOW_DIVERGENCE_THRESHOLD=0.30
HYBRID_DECISION_MIN_TAKE_TRADE_PROB=0.58
HYBRID_DECISION_MIN_EXPECTED_RETURN_BPS=6.0
HYBRID_DECISION_MAX_EXPECTED_MAE_BPS=90.0
HYBRID_DECISION_MIN_PROJECTED_RR=1.20
HYBRID_DECISION_REGIME_CONFLICT_THRESHOLD=0.70
HYBRID_DECISION_STRONG_CONFIDENCE=0.80
LEVERAGE_SIGNAL_MAX_VOLATILITY_BAND=0.35
LEVERAGE_SIGNAL_MIN_DEPTH_RATIO=0.60
LEVERAGE_SIGNAL_MAX_IMPACT_BPS_10000=10.0
LEARN_STALE_SIGNAL_MS=3600000
LEARN_MAX_FEATURE_AGE_MS=3600000
MODEL_ARTIFACTS_DIR=artifacts/models
TAKE_TRADE_MODEL_ARTIFACTS_DIR=artifacts/models/take_trade_prob
TAKE_TRADE_MODEL_MIN_ROWS=80
TAKE_TRADE_MODEL_MIN_POSITIVE_ROWS=12
TAKE_TRADE_MODEL_CALIBRATION_METHOD=sigmoid
EXPECTED_BPS_MODEL_ARTIFACTS_DIR=artifacts/models/expected_bps
EXPECTED_BPS_MODEL_MIN_ROWS=96
REGIME_CLASSIFIER_MODEL_ARTIFACTS_DIR=artifacts/models/regime_classifier
REGIME_CLASSIFIER_MIN_ROWS=120
REGIME_CLASSIFIER_MIN_PER_CLASS=8
TRAIN_CV_KFOLDS=5
TRAIN_CV_EMBARGO_PCT=0.05
# Siehe docs/replay_determinism.md: Seed + Fingerprint der deterministischen offline run_id.
TRAIN_RANDOM_STATE=42
MODEL_REGISTRY_V2_ENABLED=false
MODEL_CALIBRATION_REQUIRED=false
MODEL_CHAMPION_NAME=take_trade_prob
ENABLE_ONLINE_DRIFT_BLOCK=false
ONLINE_DRIFT_LOOKBACK_MINUTES=60
ONLINE_DRIFT_EVALUATE_ON_ANALYTICS_RUN=true
MODEL_OPS_ENABLED=false
MODEL_OPS_APPROVAL_REQUIRED=false
MODEL_OPS_SHADOW_EVAL_ENABLED=false
API_AUTH_MODE=none
SECURITY_REQUIRE_INTERNAL_NETWORK=false
SECURITY_ALLOW_EVENT_DEBUG_ROUTES=true
SECURITY_ALLOW_DB_DEBUG_ROUTES=true
SECURITY_ALLOW_ALERT_REPLAY_ROUTES=true
INTERNAL_API_KEY=<SET_ME>

TEST_DATABASE_URL=postgresql://postgres:testpass@localhost:5433/bitget_test
TEST_REDIS_URL=redis://localhost:6380/1
DATABASE_URL=postgresql://postgres:testpass@localhost:5433/bitget_test
DATABASE_URL_DOCKER=postgresql://postgres:testpass@postgres:5432/bitget_test
REDIS_URL=redis://localhost:6380/1
REDIS_URL_DOCKER=redis://redis:6379/1

NEWS_FIXTURE_MODE=true
LLM_USE_FAKE_PROVIDER=true
BITGET_DEMO_ENABLED=true
# example_only: deterministische Test-/Fixture-Watchlist, nicht Produktionswahrheit
BITGET_UNIVERSE_MARKET_FAMILIES=spot,margin,futures
BITGET_FUTURES_ALLOWED_PRODUCT_TYPES=USDT-FUTURES,USDC-FUTURES,COIN-FUTURES
BITGET_UNIVERSE_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT
FEATURE_SCOPE_SYMBOLS=BTCUSDT,ETHUSDT
FEATURE_SCOPE_TIMEFRAMES=1m,5m,15m,1H,4H
SIGNAL_SCOPE_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_SPOT_DEFAULT_QUOTE_COIN=USDT
BITGET_MARGIN_DEFAULT_QUOTE_COIN=USDT
BITGET_MARGIN_DEFAULT_ACCOUNT_MODE=isolated
BITGET_MARGIN_DEFAULT_LOAN_TYPE=normal
BITGET_FUTURES_DEFAULT_PRODUCT_TYPE=
BITGET_FUTURES_DEFAULT_MARGIN_COIN=
BITGET_PRODUCT_TYPE=
BITGET_MARKET_FAMILY=
BITGET_MARGIN_ACCOUNT_MODE=isolated
BITGET_MARGIN_LOAN_TYPE=normal
BITGET_DISCOVERY_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_SYMBOL=
BITGET_MARGIN_COIN=USDT
BITGET_REST_LOCALE=en-US
PAPER_SIM_MODE=true
PAPER_CONTRACT_CONFIG_MODE=fixture
PAPER_DEFAULT_LEVERAGE=7
PAPER_MAX_LEVERAGE=75
LEVERAGE_STOP_DISTANCE_SCALE_BPS=1500
LEVERAGE_MIN_LIQUIDATION_BUFFER_BPS=35
STOP_TRIGGER_TYPE_DEFAULT=mark_price
TP_TRIGGER_TYPE_DEFAULT=fill_price
TP1_PCT=0.30
TP2_PCT=0.30
TP3_PCT=0.40
RUNNER_TRAIL_ATR_MULT=1.0
EXIT_BREAK_EVEN_AFTER_TP_INDEX=0
EXIT_RUNNER_ENABLED=true
STRATEGY_EXEC_ENABLED=false
TELEGRAM_DRY_RUN=true

# Optional: Stack-HTTP-Integration (pytest -m integration, laufender Compose / start_local)
# API_GATEWAY_URL=http://localhost:8000
# INTEGRATION_GATEWAY_JWT_SECRET=<gleicher Wert wie GATEWAY_JWT_SECRET im Stack>
# INTEGRATION_LIVE_BROKER_URL=http://localhost:8120
# INTEGRATION_TEST_SENSITIVE_AUTH=1
