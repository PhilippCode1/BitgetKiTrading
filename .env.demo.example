# Bitget Demo-Geld Profil
#
# Diese Datei darf committed werden. Kopiere sie lokal zu `.env.demo` und trage dort echte Werte ein.
# `.env.demo` darf niemals committed werden.

APP_NAME=bitget-btc-ai
APP_ENV=shadow
PRODUCTION=false
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Demo-Modus: echte Live-Orders bleiben aus.
EXECUTION_MODE=bitget_demo
STRATEGY_EXEC_MODE=manual
LIVE_BROKER_ENABLED=true
LIVE_TRADE_ENABLE=false
BITGET_DEMO_ENABLED=true
DEMO_ORDER_SUBMIT_ENABLE=false

# Demo-Credentials nur lokal in `.env.demo` setzen.
BITGET_DEMO_API_KEY=<SET_ME>
BITGET_DEMO_API_SECRET=<SET_ME>
BITGET_DEMO_API_PASSPHRASE=<SET_ME>
BITGET_DEMO_REST_BASE_URL=https://api.bitget.com
BITGET_DEMO_WS_PUBLIC_URL=wss://wspap.bitget.com/v2/ws/public
BITGET_DEMO_WS_PRIVATE_URL=wss://wspap.bitget.com/v2/ws/private
BITGET_DEMO_PAPTRADING_HEADER=1

# Live-Credentials muessen im Demo-Profil leer bleiben.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_RELAX_CREDENTIAL_ISOLATION=false
BITGET_API_BASE_URL=https://api.bitget.com
BITGET_WS_PUBLIC_URL=wss://ws.bitget.com/v2/ws/public
BITGET_WS_PRIVATE_URL=wss://ws.bitget.com/v2/ws/private

# Demo-Testinstrumente: klein halten.
BITGET_MARKET_FAMILY=futures
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_FUTURES_DEFAULT_PRODUCT_TYPE=USDT-FUTURES
BITGET_FUTURES_DEFAULT_MARGIN_COIN=USDT
BITGET_SYMBOL=BTCUSDT
BITGET_DISCOVERY_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_UNIVERSE_MARKET_FAMILIES=futures
BITGET_FUTURES_ALLOWED_PRODUCT_TYPES=USDT-FUTURES
BITGET_UNIVERSE_SYMBOLS=BTCUSDT,ETHUSDT
BITGET_WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT
LIVE_ALLOWED_SYMBOLS=
LIVE_ALLOWED_MARKET_FAMILIES=
LIVE_ALLOWED_PRODUCT_TYPES=

# Kleine Demo-Order-Grenzen. Nicht fuer Echtgeld.
DEMO_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
DEMO_MAX_ORDER_NOTIONAL_USDT=25
DEMO_DEFAULT_ORDER_SIZE=0.001
DEMO_DEFAULT_ORDER_SIDE=buy
DEMO_DEFAULT_ORDER_TYPE=market
DEMO_DEFAULT_MARGIN_COIN=USDT
DEMO_DEFAULT_PRODUCT_TYPE=USDT-FUTURES

# Lokaler Stack
APP_BASE_URL=http://127.0.0.1:8000
API_GATEWAY_URL=http://127.0.0.1:8000
DASHBOARD_URL=http://127.0.0.1:3000
FRONTEND_URL=http://127.0.0.1:3000
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000
NEXT_PUBLIC_ADMIN_USE_SERVER_PROXY=true

# Datastores lokal setzen oder Docker-Werte nutzen.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bitget_demo
REDIS_URL=redis://localhost:6379/0
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/bitget_demo
REDIS_URL_DOCKER=redis://redis:6379/0
BITGET_USE_DOCKER_DATASTORE_DSN=false

# Pflicht-Secrets: lokale lange Zufallswerte setzen, niemals committen.
INTERNAL_API_KEY=<SET_ME_MIN_32_CHARS>
SERVICE_INTERNAL_API_KEY=<SET_ME_MIN_32_CHARS>
GATEWAY_INTERNAL_API_KEY=<SET_ME_MIN_32_CHARS>
JWT_SECRET=<SET_ME_MIN_32_CHARS>
GATEWAY_JWT_SECRET=<SET_ME_MIN_32_CHARS>
SECRET_KEY=<SET_ME_MIN_32_CHARS>
ENCRYPTION_KEY=<SET_ME_MIN_32_CHARS>
ADMIN_TOKEN=<SET_ME_MIN_32_CHARS>

# Risk/Execution sicher klein halten.
RISK_HARD_GATING_ENABLED=true
RISK_ALLOWED_LEVERAGE_MIN=7
RISK_ALLOWED_LEVERAGE_MAX=7
RISK_GOVERNOR_LIVE_RAMP_MAX_LEVERAGE=7
RISK_REQUIRE_7X_APPROVAL=true
RISK_DEFAULT_ACTION=do_not_trade
LIVE_REQUIRE_EXCHANGE_HEALTH=true
LIVE_REQUIRE_OPERATOR_RELEASE_FOR_LIVE_OPEN=true
REQUIRE_SHADOW_MATCH_BEFORE_LIVE=true
LIVE_BROKER_BLOCK_LIVE_WITHOUT_EXCHANGE_TRUTH=true
LIVE_BLOCK_SUBMIT_ON_RECONCILE_FAIL=true
LIVE_BLOCK_SUBMIT_ON_RECONCILE_DEGRADED=true
LIVE_ENABLE_PRE_FLIGHT_LIQUIDITY_GUARD=true
LIVE_LIQUIDITY_GUARD_STRICT_NO_CACHE=true
LIVE_LIQUIDITY_GUARD_MAX_SLIPPAGE_BPS=50

# Demo darf Fake-LLM nutzen, aber keine Fake-Exchange fuer echte Demo-Evidence.
LLM_USE_FAKE_PROVIDER=true
NEWS_FIXTURE_MODE=false
PAPER_SIM_MODE=false
TELEGRAM_DRY_RUN=true
