LLM_CACHE_TTL_SEC=3600
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=30000
LLM_REQUEST_TIMEOUT_MS_FAST=10000
LLM_REQUEST_TIMEOUT_MS_DEEP=30000
LLM_BACKOFF_BASE_SEC=0.5
LLM_BACKOFF_MAX_SEC=30
LLM_CIRCUIT_FAIL_THRESHOLD=3
