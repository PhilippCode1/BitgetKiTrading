# ONCHAIN_SOLANA_LISTENER_ENABLED=false

# ---------- Frontend ----------
# Docker: `docker compose build dashboard` braucht dieselben NEXT_PUBLIC_* (build.args).
# Oeffentliche HTTPS-URLs: docs/operator_urls_and_secrets.md
# Wie APP_BASE_URL (oben): 127.0.0.1 vermeidet Windows-IPv6-Fetch-Probleme
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=bitget-btc-ai
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000
DASHBOARD_DEFAULT_MARKET_FAMILY=
DASHBOARD_WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT
NEXT_PUBLIC_DEFAULT_SYMBOL=
NEXT_PUBLIC_DEFAULT_TF=1m
NEXT_PUBLIC_DEFAULT_PRODUCT=
NEXT_PUBLIC_DEFAULT_MARKET_FAMILY=
NEXT_PUBLIC_WATCHLIST_SYMBOLS=BTCUSDT,ETHUSDT
NEXT_PUBLIC_LIVE_POLL_INTERVAL_MS=2000
NEXT_PUBLIC_LIVE_SSE_PING_SEC=15
NEXT_PUBLIC_ENABLE_ADMIN=true
NEXT_PUBLIC_ENABLE_NEWS=true
NEXT_PUBLIC_ENABLE_TELEGRAM_STATUS=true
