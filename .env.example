# =========================================================
# ENV-Katalog (alle Keys, logische Gruppen) — `bitget-btc-ai`
#
# Nicht ungeprueft als `.env` / `.env.local` kopieren. Laufende Profile:
#   .env.local.example   -> Lokal / Paper (Demo+Fixture erlaubt)
#   .env.shadow.example  -> Shadow (PRODUCTION=true, keine Fake-Pfade)
#   .env.production.example -> Production (Start oft EXECUTION_MODE=shadow bis Live-Gate)
#   .env.test.example    -> Pytest/CI
# Doku: docs/env_profiles.md
#
# Zentrale Flags:
#   PRODUCTION         true = Shadow- oder Production-Profil (Härtung + Vault-Pflicht)
#   APP_ENV            local | shadow | production | test
#   EXECUTION_MODE     paper | shadow | live
#   SHADOW_TRADE_ENABLE nur bei EXECUTION_MODE=shadow
#   LIVE_TRADE_ENABLE   nur bei EXECUTION_MODE=live (+ LIVE_BROKER_ENABLED)
#   BITGET_DEMO_ENABLED / NEWS_FIXTURE_MODE / LLM_USE_FAKE_PROVIDER / TELEGRAM_DRY_RUN
#                      nur local/test; bei PRODUCTION=true verboten (config/settings.py)
#
# Gruppierung unten:
#   (1) Runtime & Deployment   (2) Broker / Execution   (3) Risk
#   (4) AI / News / LLM        (5) Security & Gateway   (6) Observability & Monitor
#   (7) Dashboard & URLs       (8) Datenhaltung        (9) Service-Engine-Tuning
#
# Website <-> API-Gateway (Browser): FRONTEND_URL-Origin muss in CORS_ALLOW_ORIGINS stehen;
# NEXT_PUBLIC_API_BASE_URL / NEXT_PUBLIC_WS_BASE_URL = oeffentlich erreichbare Gateway-URL (http+ws oder https+wss);
# Docker-Dashboard-Build: gleiche NEXT_PUBLIC_* als build-args. Siehe .env.local.example Kopfblock.
#
# URL-Welten (eine klare Erreichbarkeits-Wahrheit):
#   Host / Browser / PowerShell — alles was NICHT im Docker-Netz `bitget_ai_net` laeuft:
#     DATABASE_URL, REDIS_URL, API_GATEWAY_URL, DASHBOARD_URL
#     (typisch 127.0.0.1 oder externe Hostnamen; niemals nur „postgres“/„redis“ als Host,
#      wenn der Client nicht im Compose-Netz haengt.)
#   Container (docker-compose.yml) — Python-Services erhalten automatisch:
#     DATABASE_URL=postgresql://USER:PASS@postgres:5432/DB und REDIS_URL=redis://redis:6379/0
#     PASS kommt ausschliesslich aus POSTGRES_PASSWORD und muss mit dem User in der URL uebereinstimmen.
#   Referenz fuer Ops/CI (muss zur Container-Logik passen, nicht aus DATABASE_URL kopieren):
#     DATABASE_URL_DOCKER, REDIS_URL_DOCKER — Dienstnamen postgres und redis.
#     scripts/bootstrap_stack.* setzt DATABASE_URL_DOCKER aus POSTGRES_*, falls leer.
# =========================================================

# ---------- (1) Runtime & Deployment ----------
PRODUCTION=<true_or_false_by_profile>
APP_ENV=<local|shadow|production|test>
DEBUG=<false_in_shadow_and_production>
LOG_LEVEL=INFO
LOG_FORMAT=<plain_or_json_by_profile>
VAULT_MODE=<false|hashicorp|aws>
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=<SET_ME>
VAULT_ROLE_ID=<SET_ME>
VAULT_SECRET_ID=<SET_ME>
KMS_KEY_ID=<SET_ME>
DEPLOY_ENV=<local|shadow|production|test>
DEPLOY_SCRIPT=scripts/deploy.sh
ENABLE_DEBUG_METRICS=<true_or_false_by_profile>
GIT_REPO=https://example.com/org/bitget-btc-ai
# Docker Compose: Host-Bind fuer published Ports (127.0.0.1 = nur Loopback)
COMPOSE_EDGE_BIND=127.0.0.1
COMPOSE_LOCAL_PUBLISH_BIND=127.0.0.1

# ---------- (2) Broker / Execution Controls ----------
EXECUTION_MODE=<paper|shadow|live>
STRATEGY_EXEC_MODE=<manual_or_auto_by_profile>
SHADOW_TRADE_ENABLE=<true_only_when_execution_mode_is_shadow>
LIVE_TRADE_ENABLE=<true_only_when_execution_mode_is_live>
LIVE_BROKER_PORT=8120
LIVE_BROKER_ENABLED=<true_or_false_by_profile>
LIVE_BROKER_BASE_URL=https://live-broker.example.internal
LIVE_BROKER_WS_PRIVATE_URL=wss://live-broker.example.internal/ws/private
LIVE_BROKER_CONSUMER_GROUP=live-broker
LIVE_BROKER_CONSUMER_NAME=lb-1
LIVE_BROKER_SIGNAL_STREAM=events:signal_created
LIVE_BROKER_REFERENCE_STREAMS=events:trade_opened,events:trade_updated,events:trade_closed
# Operator-Intel -> Redis events:operator_intel -> alert-engine Outbox (nur lesend/informativ)
LIVE_OPERATOR_INTEL_OUTBOX_ENABLED=false
ORDER_IDEMPOTENCY_PREFIX=bgai
LIVE_RECONCILE_INTERVAL_SEC=15
# Reconcile: Ack-/WS-/Fill-Divergenz (siehe docs/recovery_runbook.md)
LIVE_RECONCILE_ORDER_ACK_STALE_SEC=120
LIVE_RECONCILE_PRIVATE_WS_STALE_SEC=300
LIVE_RECONCILE_JOURNAL_TAIL_LIMIT=200
LIVE_RECONCILE_MISSING_EXCHANGE_ACK_DEGRADES=true
LIVE_RECONCILE_FILL_DRIFT_DEGRADES=false
LIVE_RECONCILE_WS_STALE_DEGRADES=false
LIVE_RECONCILE_REST_CATCHUP_ON_WS_STALE=false
LIVE_KILL_SWITCH_ENABLED=true
INSTRUMENT_CATALOG_REFRESH_INTERVAL_SEC=300
INSTRUMENT_CATALOG_CACHE_TTL_SEC=900
INSTRUMENT_CATALOG_MAX_STALE_SEC=1800
LIVE_ALLOWED_SYMBOLS=<OPTIONAL_LIVE_ALLOWLIST_SYMBOLS_FROM_DISCOVERY>
LIVE_ALLOWED_MARKET_FAMILIES=<OPTIONAL_LIVE_ALLOWLIST_MARKET_FAMILIES>
LIVE_ALLOWED_PRODUCT_TYPES=<OPTIONAL_LIVE_ALLOWLIST_PRODUCT_TYPES>
LIVE_REQUIRE_EXCHANGE_HEALTH=true
# Opening-Orders nur mit gebundener KI-Execution-Decision (live-broker orders/create)
LIVE_REQUIRE_EXECUTION_BINDING=false
# Zusaetzlich explizite Operator-Freigabe pro execution_id (Internal Ops-Route)
LIVE_REQUIRE_OPERATOR_RELEASE_FOR_LIVE_OPEN=false
LIVE_BROKER_HTTP_TIMEOUT_SEC=10
LIVE_BROKER_HTTP_MAX_RETRIES=2
LIVE_BROKER_HTTP_RETRY_BASE_SEC=0.25
LIVE_BROKER_HTTP_RETRY_MAX_SEC=2.0
LIVE_BROKER_CIRCUIT_FAIL_THRESHOLD=3
LIVE_BROKER_CIRCUIT_OPEN_SEC=30
LIVE_BROKER_SERVER_TIME_SYNC_SEC=20
LIVE_BROKER_SERVER_TIME_MAX_SKEW_MS=5000
LIVE_ORDER_TIMEOUT_SEC=300
LIVE_EXITS_ENABLED=true
# Preflight / Ausfuehrungs-Safety (deterministisch, ohne LLM) — siehe docs/emergency_runbook.md
# 0 = Katalog-Frische-Check aus; >0 blockt Orders wenn Instrument-Metadata aelter ist (Sekunden)
LIVE_PREFLIGHT_MAX_CATALOG_METADATA_AGE_SEC=0
# Market-Order: max. halbe Spread-Breite in bps (Mid-Referenz); leer = Guard aus
LIVE_EXECUTION_MAX_SPREAD_HALF_BPS_MARKET=
# Preset-Stop: Mindestabstand ref->Stop in bps bzw. Mindestmultiples des Buch-Spreads; leer = aus
LIVE_PRESET_STOP_MIN_DISTANCE_BPS=
LIVE_PRESET_STOP_MIN_SPREAD_MULT=
# Submit blockieren wenn letzter Reconcile-Status fail/degraded (siehe LIVE_BLOCK_SUBMIT_ON_RECONCILE_*)
LIVE_BLOCK_SUBMIT_ON_RECONCILE_FAIL=true
LIVE_BLOCK_SUBMIT_ON_RECONCILE_DEGRADED=false
# Reduce-only nur wenn Exchange-Positions-Snapshot zur Seite passt (empfohlen bei private API)
LIVE_REQUIRE_EXCHANGE_POSITION_FOR_REDUCE_ONLY=true
# Optional: Public-Probe vor jedem Submit (zusaetzlich zu Spread-/Stop-Guards)
LIVE_PROBE_PUBLIC_API_BEFORE_ORDER_SUBMIT=false
# Nach fehlgeschlagener Duplicate-Order-Recovery optional Safety-Latch armieren
LIVE_SAFETY_LATCH_ON_DUPLICATE_RECOVERY_FAIL=false
# Shadow-vs-Live-Abgleich vor Live-Candidate (docs/shadow_live_divergence.md)
REQUIRE_SHADOW_MATCH_BEFORE_LIVE=false
SHADOW_LIVE_MAX_TIMING_SKEW_MS=180000
SHADOW_LIVE_MAX_LEVERAGE_DELTA=0
SHADOW_LIVE_MAX_SIGNAL_SHADOW_DIVERGENCE_0_1=0.15
SHADOW_LIVE_TIMING_VIOLATION_HARD=false
# Optional: harte Obergrenze fuer geschaetzte Slippage (bps); leer = pruefung aus
SHADOW_LIVE_MAX_SLIPPAGE_EXPECTATION_BPS=

# ---------- (3) Global Risk Controls ----------
RISK_HARD_GATING_ENABLED=true
RISK_ALLOWED_LEVERAGE_MIN=7
RISK_ALLOWED_LEVERAGE_MAX=75
# Bei PRODUCTION + LIVE_TRADE_ENABLE + MAX>7 Pflicht: RISK_ELEVATED_LEVERAGE_LIVE_ACK=true
RISK_ELEVATED_LEVERAGE_LIVE_ACK=false
RISK_REQUIRE_7X_APPROVAL=true
RISK_DEFAULT_ACTION=do_not_trade
RISK_MIN_SIGNAL_STRENGTH=65
RISK_MIN_PROBABILITY=0.65
RISK_MIN_RISK_SCORE=60
RISK_MIN_EXPECTED_RETURN_BPS=5
RISK_MAX_EXPECTED_MAE_BPS=120
RISK_MIN_PROJECTED_RR=1.15
RISK_MAX_POSITION_RISK_PCT=0.02
RISK_MAX_ACCOUNT_MARGIN_USAGE=0.35
RISK_MAX_ACCOUNT_DRAWDOWN_PCT=0.10
RISK_MAX_DAILY_DRAWDOWN_PCT=0.04
RISK_MAX_WEEKLY_DRAWDOWN_PCT=0.08
RISK_MAX_DAILY_LOSS_USDT=1000
RISK_MAX_POSITION_NOTIONAL_USDT=5000
RISK_MAX_CONCURRENT_POSITIONS=1
RISK_FORCE_REDUCE_ONLY_ON_ALERT=true
RISK_GOVERNOR_LIVE_RAMP_MAX_LEVERAGE=7

# ---------- Model Ops (Grenze Risk / MLOps) ----------
MODEL_OPS_ENABLED=<true_or_false_by_profile>
MODEL_OPS_REGISTRY_URI=https://mlflow.example.internal
MODEL_OPS_ACTIVE_MODEL_TAG=signal-v1
MODEL_OPS_APPROVAL_REQUIRED=true
MODEL_OPS_SHADOW_EVAL_ENABLED=true
MODEL_OPS_DRIFT_ALERT_THRESHOLD=0.15
MODEL_OPS_ROLLBACK_ON_DRIFT=true
MODEL_OPS_MIN_SAMPLE_SIZE=50

# ---------- (5) Security (App-wide) ----------
API_AUTH_MODE=<none|api_key|oauth2|mtls>
SECURITY_REQUIRE_INTERNAL_NETWORK=<true_or_false_by_profile>
SECURITY_ALLOW_EVENT_DEBUG_ROUTES=<true_local_and_test_only>
SECURITY_ALLOW_DB_DEBUG_ROUTES=<true_local_and_test_only>
SECURITY_ALLOW_ALERT_REPLAY_ROUTES=<true_local_and_test_only>
# INTERNAL_API_KEY: X-Internal-Service-Key; Pydantic-Alias SERVICE_INTERNAL_API_KEY — nicht GATEWAY_INTERNAL_API_KEY.
INTERNAL_API_KEY=<SET_ME>
ADMIN_TOKEN=<SET_ME>
SECRET_KEY=<SET_ME>
JWT_SECRET=<SET_ME>
ENCRYPTION_KEY=<SET_ME>

# ---------- (5b) Gateway + (7) Dashboard ----------
APP_NAME=bitget-btc-ai
APP_PORT=8000
APP_BASE_URL=https://api.example.com
FRONTEND_URL=https://dashboard.example.com
TIMEZONE=Europe/Berlin
CORS_ALLOW_ORIGINS=https://dashboard.example.com
# API-Gateway: sensibler Pfad-Schutz (JWT HS256 und/oder interner Key); Rate-Limits (Redis)
GATEWAY_JWT_SECRET=<SET_ME>
GATEWAY_JWT_AUDIENCE=api-gateway
GATEWAY_JWT_ISSUER=bitget-btc-ai-gateway
# Prompt 10: exakter JWT-Claim `sub` fuer Philipp (super_admin in portal_roles / platform_role nur hier wirksam)
GATEWAY_SUPER_ADMIN_SUBJECT=
# X-Gateway-Internal-Key (Gateway-intern/Admin) — eigenstaendiges Secret, nicht INTERNAL_API_KEY.
GATEWAY_INTERNAL_API_KEY=<optional_service_key>
# true erzwingt Auth auf sensiblen Routen auch wenn PRODUCTION=false
GATEWAY_ENFORCE_SENSITIVE_AUTH=<true_in_prod_or_tests>
# Nur wenn sensibles Auth NICHT erzwungen: Legacy X-Admin-Token (Dev/Paper)
# Default im Code: false — nur lokal explizit true setzen (X-Admin-Token).
GATEWAY_ALLOW_LEGACY_ADMIN_TOKEN=false
# Gateway /ready: Redis PING (Kern-Check core_redis) — Timeout und Retries gegen Docker-Flakes
GATEWAY_READINESS_REDIS_TIMEOUT_SEC=5.0
GATEWAY_READINESS_REDIS_RETRIES=2
GATEWAY_RL_PUBLIC_PER_MINUTE=240
GATEWAY_RL_SENSITIVE_PER_MINUTE=90
GATEWAY_RL_ADMIN_MUTATE_PER_MINUTE=24
GATEWAY_RL_SAFETY_MUTATE_PER_MINUTE=12
GATEWAY_RL_SAFETY_BURST_PER_10S=4
# Leer = volles Rollenset fuer X-Gateway-Internal-Key; sonst z.B. gateway:read,operator:mutate
GATEWAY_INTERNAL_KEY_ROLES=
GATEWAY_MANUAL_ACTION_SECRET=<optional_or_reuse_jwt_secret>
GATEWAY_MANUAL_ACTION_TTL_SEC=120
# null = bei sensiblem Auth true, sonst false
GATEWAY_MANUAL_ACTION_REQUIRED=
GATEWAY_MANUAL_ACTION_REDIS_REPLAY_GUARD=true
# Nur lokal: Mutationen ohne Login (nicht in Prod)
# Nur ohne PRODUCTION und ohne GATEWAY_ENFORCE_SENSITIVE_AUTH wirksam.
GATEWAY_ALLOW_ANONYMOUS_SAFETY_MUTATIONS=false
# Production + Live-Handel: Commerce, Telegram-Bot, Metering, Operator-Release erzwingen (siehe docs/execution_mode_tiers.md)
EXECUTION_LIVE_STRICT_PREREQUISITES=false

# Kommerzielle Transparenz (siehe docs/commercial_transparency.md)
COMMERCIAL_ENABLED=false
COMMERCIAL_DEFAULT_TENANT_ID=default
COMMERCIAL_METER_SECRET=
# Prompt 12: Vertrags-PDF, Mock-E-Sign, Webhook POST /v1/commerce/webhooks/contract-esign
# Signatur: HMAC-SHA256(hex) ueber JSON mit sort_keys=true, separatoren (",",":") — Header X-Commercial-Contract-Signature
COMMERCIAL_CONTRACT_WEBHOOK_SECRET=
COMMERCIAL_CONTRACT_ESIGN_PROVIDER=mock
# Nur non-production: Dashboard „Mock-Signatur“ ohne Webhook
COMMERCIAL_CONTRACT_ALLOW_MOCK_CUSTOMER_COMPLETE=false
# true: POST .../lifecycle/ack-contract-signed sperren (nur E-Sign-Flow)
COMMERCIAL_CONTRACT_ENFORCE_SIGNING_WORKFLOW=false
# Prompt 13: Abo-Plaene, Rechnungen, Finanz-Ledger (Migration 609_subscription_billing_ledger.sql) — keine zusaetzlichen ENV-Pflichtfelder
# Kunden-Telegram: Deep-Link t.me/<username>?start=link_<token> (ohne @)
TELEGRAM_BOT_USERNAME=
# Gateway: ohne Verknuepfung nur Konto-Bereich in der Console (Dashboard spiegelt NEXT_PUBLIC_*)
COMMERCIAL_TELEGRAM_REQUIRED_FOR_CONSOLE=false
# API-Billing: taegliche Pauschale vom Prepaid (Migration 600, docs/billing_engine.md)
BILLING_DAILY_API_FEE_USD=50
BILLING_MIN_BALANCE_NEW_TRADE_USD=50
BILLING_WARNING_BALANCE_USD=100
BILLING_CRITICAL_BALANCE_USD=50
# Gewinnbeteiligung High-Water-Mark (Prompt 15, Migration 611, docs/profit_fee_prompt15.md)
PROFIT_FEE_MODULE_ENABLED=true
# 1000 = 10 % auf inkrementelle Gewinnbasis (Basispunkte / 10000)
PROFIT_FEE_RATE_BASIS_POINTS=1000
# Settlement / Treasury (Prompt 16, Migration 612, docs/profit_settlement_prompt16.md)
PROFIT_FEE_SETTLEMENT_ENABLED=true
# true = zweite Admin-Freigabe vor manueller Auszahlung
PROFIT_FEE_SETTLEMENT_TREASURY_SECONDARY_APPROVAL=false
# Paper- / Live-Broker: neue Positionen/Opening-Orders nur bei ausreichendem Prepaid
BILLING_PREPAID_GATE_ENABLED=false
BILLING_PREPAID_TENANT_ID=default
# Live-Broker: Modul-Mate-Kommerzgates aus DB (Migration 604, docs/live_broker.md)
MODUL_MATE_GATE_ENFORCEMENT=false
MODUL_MATE_GATE_TENANT_ID=default
# Wenn true (Default in Code): Exchange-Submit laedt immer tenant_modul_mate_gates — erfordert DATABASE_URL.
# OR mit MODUL_MATE_GATE_ENFORCEMENT: mindestens eines sollte in Production mit Live-Submit aktiv sein.
LIVE_BROKER_REQUIRE_COMMERCIAL_GATES=true
# Einzahlungen (PROMPT 18, siehe docs/payment_architecture.md)
PAYMENT_CHECKOUT_ENABLED=false
PAYMENT_MODE=sandbox
PAYMENT_STRIPE_ENABLED=false
PAYMENT_STRIPE_SECRET_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=
PAYMENT_STRIPE_SUCCESS_URL=
PAYMENT_STRIPE_CANCEL_URL=
# z.B. card,link,alipay,wechat_pay — je nach Stripe-Konto/Region
PAYMENT_STRIPE_METHOD_TYPES=card
PAYMENT_MOCK_ENABLED=true
PAYMENT_MOCK_WEBHOOK_SECRET=
# Prompt 14: internationale Rails (Wise-Ingest, PayPal-Stub bis Commerce angebunden)
PAYMENT_WISE_WEBHOOK_ENABLED=false
PAYMENT_WISE_WEBHOOK_SECRET=
PAYMENT_PAYPAL_STUB_WEBHOOK_ENABLED=false
PAYMENT_PAYPAL_STUB_WEBHOOK_SECRET=
# Security-Header: HSTS nur setzen wenn TLS am Client endet (oder Proxy davor)
GATEWAY_SEND_HSTS=false
# JSON-API-CSP; leer = Header weglassen
GATEWAY_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
# SSE-Session-Cookie: Secure explizit true bei TLS ohne PRODUCTION=true
GATEWAY_SSE_COOKIE_SECURE=
GATEWAY_SSE_COOKIE_SAMESITE=lax
# Dashboard (Next.js Server): vollstaendiger Authorization-Header zum Gateway, nie NEXT_PUBLIC_*
DASHBOARD_GATEWAY_AUTHORIZATION=Bearer <jwt_mit_gateway_roles>
NEXT_PUBLIC_ADMIN_USE_SERVER_PROXY=<false_local_true_prod>
# Muss zu COMMERCIAL_TELEGRAM_REQUIRED_FOR_CONSOLE passen, wenn Console-Gate aktiv ist
NEXT_PUBLIC_COMMERCIAL_TELEGRAM_REQUIRED_FOR_CONSOLE=false
DATA_STALE_WARN_MS=900000
DASHBOARD_DEFAULT_SYMBOL=
DASHBOARD_DEFAULT_TF=1m
DASHBOARD_PAGE_SIZE=50
LIVE_STATE_MAX_CANDLES=2000
LIVE_STATE_DEFAULT_CANDLES=500
LIVE_SSE_ENABLED=true
LIVE_SSE_PING_SEC=15
HEALTH_URL_MARKET_STREAM=http://market-stream:8010/ready
HEALTH_URL_FEATURE_ENGINE=http://feature-engine:8020/ready
HEALTH_URL_STRUCTURE_ENGINE=http://structure-engine:8030/ready
HEALTH_URL_SIGNAL_ENGINE=http://signal-engine:8050/ready
HEALTH_URL_DRAWING_ENGINE=http://drawing-engine:8040/ready
HEALTH_URL_NEWS_ENGINE=http://news-engine:8060/ready
HEALTH_URL_LLM_ORCHESTRATOR=http://llm-orchestrator:8070/ready
HEALTH_URL_PAPER_BROKER=http://paper-broker:8085/ready
HEALTH_URL_LEARNING_ENGINE=http://learning-engine:8090/ready
HEALTH_URL_ALERT_ENGINE=http://alert-engine:8100/ready
HEALTH_URL_MONITOR_ENGINE=http://monitor-engine:8110/ready
HEALTH_URL_LIVE_BROKER=http://live-broker:8120/ready
# HEALTH_URL_* im Gateway: unter Compose Service-Namen; auf dem Host http://127.0.0.1:<PORT>/ready

# ---------- Script Healthcheck (Host-Sicht, published Ports / Edge-URL) ----------
# LLM_ORCH_URL: Basis-URL ohne /ready fuer scripts/healthcheck.sh. Gateway-HTTP nutzt LLM_ORCH_BASE_URL
# (News/LLM-Abschnitt) oder leitet Host aus HEALTH_URL_LLM_ORCHESTRATOR ab — siehe 03_ENV_SECRETS_AUTH_MATRIX.md §2.2.
API_GATEWAY_URL=http://127.0.0.1:8000
MARKET_STREAM_URL=http://127.0.0.1:8010
FEATURE_ENGINE_URL=http://127.0.0.1:8020
STRUCTURE_ENGINE_URL=http://127.0.0.1:8030
DRAWING_ENGINE_URL=http://127.0.0.1:8040
SIGNAL_ENGINE_URL=http://127.0.0.1:8050
NEWS_ENGINE_URL=http://127.0.0.1:8060
LLM_ORCH_URL=http://127.0.0.1:8070
PAPER_BROKER_URL=http://127.0.0.1:8085
LEARNING_ENGINE_URL=http://127.0.0.1:8090
ALERT_ENGINE_URL=http://127.0.0.1:8100
MONITOR_ENGINE_URL=http://127.0.0.1:8110
LIVE_BROKER_URL=http://127.0.0.1:8120
DASHBOARD_URL=http://127.0.0.1:3000

# ---------- Alert Engine ----------
ALERT_ENGINE_PORT=8100
TELEGRAM_BOT_TOKEN=<SET_ME>
TELEGRAM_MODE=<getUpdates_or_webhook_by_profile>
TELEGRAM_LONGPOLL_TIMEOUT_SEC=30
TELEGRAM_ALLOWED_UPDATES=message,callback_query
TELEGRAM_ALLOWED_CHAT_IDS=<SET_ME>
TELEGRAM_SEND_MAX_PER_SEC=1
TELEGRAM_SEND_MAX_PER_MIN_PER_CHAT=20
TELEGRAM_SEND_MAX_RETRIES=3
TELEGRAM_DRY_RUN=<true_local_and_test_only>
TELEGRAM_PARSE_MODE=none
TELEGRAM_MESSAGE_SAFE_LEN=3500
# Thread-Verknuepfung operator_intel: Redis ae:opintel:thread:{correlation_id} -> Telegram message_id
TELEGRAM_OPERATOR_THREAD_TTL_SEC=604800
# Send-Versuche je Outbox-Zeile bevor endgueltig failed (Backoff im Sender)
TELEGRAM_OUTBOX_MAX_SEND_ATTEMPTS=8
TELEGRAM_WEBHOOK_URL=https://alerts.example.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=<SET_ME>
TELEGRAM_CHAT_ID=<SET_ME>
TELEGRAM_ALERTS_ENABLED=<true_or_false_by_profile>
# Telegram-Operator: zweistufige Freigaben gegen live-broker (Standard aus)
TELEGRAM_OPERATOR_ACTIONS_ENABLED=false
TELEGRAM_OPERATOR_CONFIRM_TTL_SEC=300
# Optional: nur diese Telegram-user_id (numerisch, CSV) duerfen Operator-Befehle; leer = keine User-RBAC
TELEGRAM_OPERATOR_ALLOWED_USER_IDS=
# Optional: drittes Argument bei /release_confirm und /emerg_confirm (Manual-Action-Token, nicht loggen)
TELEGRAM_OPERATOR_CONFIRM_TOKEN=
# Origin live-broker fuer interne Ops-Calls (gleicher INTERNAL_API_KEY wie zwischen Services)
ALERT_ENGINE_LIVE_BROKER_BASE_URL=http://live-broker:8120
ALERT_SIGNAL_GROSS_THRESHOLD=80
ALERT_SIGNAL_CORE_THRESHOLD=65
ALERT_NEWS_THRESHOLD=80
ALERT_DEDUPE_MINUTES_GROSS=10
ALERT_DEDUPE_MINUTES_CORE=10
ALERT_DEDUPE_MINUTES_TREND=10
ALERT_DEDUPE_MINUTES_NEWS=30
ALERT_CONSUMER_GROUP=alert-engine
ALERT_CONSUMER_NAME=ae-1
ALERT_EVENT_BLOCK_MS=2000
ALERT_EVENT_BATCH=50

# ---------- Postgres ----------
# POSTGRES_PASSWORD ist die einzige Passwort-Wahrheit; DATABASE_URL* muss dasselbe Passwort im user:pass-Teil haben.
POSTGRES_HOST=<set_per_profile>
POSTGRES_PORT=5432
POSTGRES_DB=bitget_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<SET_ME>
DATABASE_URL=postgresql://postgres:<SET_ME>@127.0.0.1:5432/bitget_ai
DATABASE_URL_DOCKER=postgresql://postgres:<SET_ME>@postgres:5432/bitget_ai

# ---------- Redis ----------
REDIS_HOST=<set_per_profile>
REDIS_PORT=6379
REDIS_PASSWORD=<SET_ME_or_blank>
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
EVENTBUS_DEFAULT_BLOCK_MS=2000
